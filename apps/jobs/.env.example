# Postgres connection (matches root docker-compose.yml)
DATABASE_URL="postgresql://capbase:capbase@localhost:5433/capbase?schema=public"

# Optional HTTP health port for the worker (Docker healthcheck).
PORT=3002

# SEC requires a descriptive User-Agent with a contact email. Be a good citizen.
SEC_USER_AGENT="capbase-ingest (you@example.com)"

# Cron schedule for the daily SEC Form D ingest (node-cron syntax). 6am daily.
CRON_SCHEDULE="0 6 * * *"

# Run one ingest pass immediately on boot (useful in containers / first run).
INGEST_ON_BOOT="false"

# Max Form D filings to process per run (keeps runs bounded + polite to SEC).
INGEST_LIMIT="50"
